<UserControl x:Class="DIndex.App.Views.Pages.LogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{StaticResource Log.Title}" Style="{StaticResource TitleLarge}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                Padding="16,12" Margin="0,0,0,16">
            <DockPanel>
                <ComboBox DockPanel.Dock="Left" Width="180" Margin="0,0,12,0"
                          SelectedIndex="{Binding FilterIndex}">
                    <ComboBoxItem Content="{StaticResource Log.FilterAll}"/>
                    <ComboBoxItem Content="{StaticResource Log.Insert}"/>
                    <ComboBoxItem Content="{StaticResource Log.Delete}"/>
                    <ComboBoxItem Content="{StaticResource Log.Update}"/>
                </ComboBox>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            Content="{StaticResource Log.Undo}"
                            Command="{Binding UndoCommand}"/>
                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            Content="{StaticResource Log.Redo}"
                            Command="{Binding RedoCommand}"/>
                    <Button Style="{StaticResource DangerButton}"
                            Content="{StaticResource Log.Clear}"
                            Command="{Binding ClearLogCommand}"/>
                </StackPanel>

                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMutedBrush}">
                    <Run Text="{Binding Entries.Count, Mode=OneWay}"/><Run Text=" операцій"/>
                </TextBlock>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10">
            <DataGrid ItemsSource="{Binding Entries}" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{StaticResource Log.ColTime}"
                                        Binding="{Binding Timestamp, Converter={StaticResource TsToStr}}" Width="160"/>
                    <DataGridTemplateColumn Header="{StaticResource Log.ColType}" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="6,2" Margin="4,2"
                                        Background="{Binding Type, Converter={StaticResource OpTypeColor}}">
                                    <TextBlock Text="{Binding Type, Converter={StaticResource OpTypeStr}}"
                                               Foreground="White" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{StaticResource Log.ColId}"
                                        Binding="{Binding EntityId}" Width="100"/>
                    <DataGridTextColumn Header="{StaticResource Log.ColDesc}"
                                        Binding="{Binding Description}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}" Style="{StaticResource BodyText}"
                   Margin="0,8,0,0" Foreground="{StaticResource TextMutedBrush}"/>
    </Grid>
</UserControl>
