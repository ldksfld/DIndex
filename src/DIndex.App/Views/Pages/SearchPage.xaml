<UserControl x:Class="DIndex.App.Views.Pages.SearchPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid Margin="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{StaticResource Search.Title}" Style="{StaticResource TitleLarge}" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="4" Margin="0,0,0,16">
            <UniformGrid Rows="1" Columns="3">
                <RadioButton Content="{StaticResource Search.ById}"
                             GroupName="SearchMode"
                             IsChecked="{Binding SearchMode, Converter={StaticResource IntEqual}, ConverterParameter=0, Mode=TwoWay}"
                             Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8" FontFamily="Segoe UI"/>
                <RadioButton Content="{StaticResource Search.ByRange}"
                             GroupName="SearchMode"
                             IsChecked="{Binding SearchMode, Converter={StaticResource IntEqual}, ConverterParameter=1, Mode=TwoWay}"
                             Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8" FontFamily="Segoe UI"/>
                <RadioButton Content="{StaticResource Search.ByKey}"
                             GroupName="SearchMode"
                             IsChecked="{Binding SearchMode, Converter={StaticResource IntEqual}, ConverterParameter=2, Mode=TwoWay}"
                             Foreground="{StaticResource TextPrimaryBrush}" Padding="12,8" FontFamily="Segoe UI"/>
            </UniformGrid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="20" Margin="0,0,0,16">
            <StackPanel>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchMode}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="0,0,12,0"
                             Text="{Binding SearchId, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{StaticResource Search.Id}"/>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                            Content="{StaticResource Search.Button}"
                            Command="{Binding SearchCommand}" MinWidth="100"/>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchMode}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="0,0,8,0"
                             Text="{Binding RangeFrom, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{StaticResource Search.From}"/>
                    <TextBox Grid.Column="1" Margin="0,0,12,0"
                             Text="{Binding RangeTo, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{StaticResource Search.To}"/>
                    <Button Grid.Column="2" Style="{StaticResource PrimaryButton}"
                            Content="{StaticResource Search.Button}"
                            Command="{Binding SearchCommand}" MinWidth="100"/>
                </Grid>

                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchMode}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Margin="0,0,12,0"
                             Text="{Binding KeyPrefix, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{StaticResource Search.KeyPrefix}"/>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}"
                            Content="{StaticResource Search.Button}"
                            Command="{Binding SearchCommand}" MinWidth="100"/>
                </Grid>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"
                           FontSize="12" Margin="0,8,0,0"
                           Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" CornerRadius="10">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,12" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{StaticResource Search.Results}" Style="{StaticResource TitleSmall}"/>
                        <TextBlock Margin="12,0,0,0" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center">
                            <Run Text="{Binding ResultCount, Mode=OneWay}"/><Run Text=" записів"/>
                        </TextBlock>
                        <TextBlock Margin="12,0,0,0" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                                   Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
                            <Run Text="· "/>
                            <Run Text="{StaticResource Search.Time}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding ResultTime, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False"
                          IsReadOnly="True" SelectionMode="Single" Margin="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="{StaticResource Search.ColId}" Binding="{Binding Id}" Width="100"/>
                        <DataGridTextColumn Header="{StaticResource Search.ColKey}" Binding="{Binding Key}" Width="200"/>
                        <DataGridTextColumn Header="{StaticResource Search.ColData}" Width="*">
                            <DataGridTextColumn.Binding>
                                <Binding Path="Data" Converter="{StaticResource Truncate}" ConverterParameter="40"/>
                            </DataGridTextColumn.Binding>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="{StaticResource Search.ColTime}"
                                            Binding="{Binding Timestamp, Converter={StaticResource TsToStr}}" Width="160"/>
                        <DataGridTextColumn Header="{StaticResource Search.ColStatus}"
                                            Binding="{Binding Flags, Converter={StaticResource FlagsToStr}}" Width="100"/>
                        <DataGridTemplateColumn Header="{StaticResource Search.Delete}" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource DangerButton}" Content="✕"
                                            Padding="8,4" Margin="4,2"
                                            Command="{Binding DataContext.DeleteResultCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding StatusMessage}" Style="{StaticResource BodyText}"
                   Margin="0,8,0,0" Foreground="{StaticResource TextMutedBrush}"/>
    </Grid>
</UserControl>
