<UserControl x:Class="DIndex.App.Views.Pages.BenchmarkPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <TextBlock Text="{StaticResource Benchmark.Title}" Style="{StaticResource TitleLarge}" Margin="0,0,0,4"/>
            <TextBlock Text="{StaticResource Benchmark.Warning}"
                       Foreground="{StaticResource WarningBrush}" FontSize="12" Margin="0,0,0,16"/>

            <Border Background="{StaticResource ErrorBrush}" CornerRadius="10" Padding="14,10" Margin="0,0,0,16"
                    Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="White" FontSize="13"
                           TextWrapping="Wrap" FontFamily="Segoe UI"/>
            </Border>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="20" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="{StaticResource Benchmark.Scenarios}" Style="{StaticResource TitleSmall}" Margin="0,0,0,12"/>
                        <CheckBox Content="{StaticResource Benchmark.BstVsLinear}"
                                  IsChecked="{Binding ScenarioBstLinear}" Margin="0,4"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                        <CheckBox Content="{StaticResource Benchmark.QuickSort}"
                                  IsChecked="{Binding ScenarioQuickSort}" Margin="0,4"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                        <CheckBox Content="{StaticResource Benchmark.InterpolSearch}"
                                  IsChecked="{Binding ScenarioInterpolation}" Margin="0,4"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="20" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{StaticResource Benchmark.Sizes}" Style="{StaticResource TitleSmall}" Margin="0,0,0,12"/>
                        <CheckBox Content="N = 1 000" IsChecked="{Binding N1k}" Margin="0,4"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                        <CheckBox Content="N = 10 000" IsChecked="{Binding N10k}" Margin="0,4"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                        <CheckBox Content="N = 100 000" IsChecked="{Binding N100k}" Margin="0,4"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                        <CheckBox Content="N = 1 000 000" IsChecked="{Binding N1m}" Margin="0,4"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"
                        Content="{StaticResource Benchmark.Run}"
                        Command="{Binding RunBenchmarksCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                <Button Style="{StaticResource DangerButton}" Margin="0,0,12,0"
                        Content="Скасувати"
                        Command="{Binding CancelRunCommand}"
                        Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"/>
                <Button Style="{StaticResource SecondaryButton}"
                        Content="{StaticResource Benchmark.OpenReport}"
                        Command="{Binding OpenReportCommand}"
                        Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,10"
                                 Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding ProgressText}" FontFamily="Consolas" FontSize="12"
                               Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding ElapsedText}" FontFamily="Consolas" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0"
                               Visibility="{Binding ElapsedText, Converter={StaticResource NullToVis}}"/>
                    <TextBlock FontFamily="Consolas" FontSize="10" Margin="0,6,0,0"
                               Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"
                               Visibility="{Binding ExePathDisplay, Converter={StaticResource NullToVis}}">
                        <Run Text="EXE: "/>
                        <Run Text="{Binding ExePathDisplay, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                    Visibility="{Binding HasRows, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="16,12"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Результати аналізу" Style="{StaticResource TitleSmall}"/>
                    </Border>
                    <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True" MaxHeight="400">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{StaticResource Benchmark.ColMethod}" Binding="{Binding Method}" Width="*"/>
                            <DataGridTextColumn Header="{StaticResource Benchmark.ColN}" Binding="{Binding N}" Width="80"/>
                            <DataGridTextColumn Header="{StaticResource Benchmark.ColMean}" Binding="{Binding MeanNs}" Width="140"/>
                            <DataGridTextColumn Header="{StaticResource Benchmark.ColStdDev}" Binding="{Binding StdDev}" Width="100"/>
                            <DataGridTextColumn Header="{StaticResource Benchmark.ColAlloc}" Binding="{Binding Alloc}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
