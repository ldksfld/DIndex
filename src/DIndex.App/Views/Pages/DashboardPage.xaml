<UserControl x:Class="DIndex.App.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DIndex.App.ViewModels"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{StaticResource Dashboard.Title}" Style="{StaticResource TitleLarge}"/>
                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}"
                        Content="Оновити метрики" Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
            </Grid>

            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,12"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>

            <UniformGrid Rows="2" Columns="3" Margin="0,0,0,16">
                <Border Margin="0,0,8,8" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Всього записів" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding TotalCount}" Style="{StaticResource MetricValue}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Margin="4,0,4,8" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Активних" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding ActiveCount}" Style="{StaticResource MetricValue}"
                                   Margin="0,8,0,0" Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>
                <Border Margin="8,0,0,8" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Видалених" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding DeletedCount}" Style="{StaticResource MetricValue}"
                                   Margin="0,8,0,0" Foreground="{StaticResource ErrorBrush}"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,8,8,0" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Розмір індексу (МБ)" Style="{StaticResource LabelText}"/>
                        <TextBlock Style="{StaticResource MetricValue}" Margin="0,8,0,0"
                                   Foreground="{StaticResource InfoBrush}">
                            <Run Text="{Binding IndexSizeMb, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Margin="4,8,4,0" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Останній пошук (мс)" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding LastSearchMs}" Style="{StaticResource MetricValue}"
                                   Margin="0,8,0,0" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>
                <Border Margin="8,8,0,0" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Глибина індексу" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding IndexDepthDisplay}" Style="{StaticResource MetricValue}"
                                   Margin="0,8,0,0" Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="10"
                    Padding="16,12" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="Сторінок пам'яті: " Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                        <TextBlock Text="{Binding PageCount}" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="Заповненість: " Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold">
                            <Run Text="{Binding FillPercent, Mode=OneWay}"/><Run Text=" %"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock Text="Операцій у журналі: " Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                        <TextBlock Text="{Binding LogCount}" Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="{StaticResource WarningBrush}" CornerRadius="10"
                    Padding="14,10" Margin="0,0,0,16"
                    Visibility="{Binding IsIndexDeep, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠" FontSize="16" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Foreground="White" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap">
                        Індекс став занадто глибоким — продуктивність може погіршитись.
                        Рекомендовано перебудувати індекс випадковим порядком ключів.
                    </TextBlock>
                </StackPanel>
            </Border>

            <TextBlock Text="Швидкі дії" Style="{StaticResource TitleSmall}" Margin="0,0,0,10"/>
            <WrapPanel Margin="0,0,0,16">
                <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,0" MinWidth="160"
                        Command="{Binding DataContext.NavigateRecordsCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📝" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Новий запис" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,0" MinWidth="160"
                        Command="{Binding DataContext.NavigateSearchCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Швидкий пошук" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SuccessButton}" MinWidth="180"
                        Command="{Binding DataContext.Snapshot.SaveCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock Text="Зберегти Snapshot" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12"
                    Padding="20"
                    Visibility="{Binding HasChartData, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Активність за часом" Style="{StaticResource TitleSmall}" Margin="0,0,0,12"/>
                    <Grid Height="110">
                        <ItemsControl ItemsSource="{Binding ChartBars}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Rectangle Grid.Row="0"
                                                   Fill="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Bottom"
                                                   Height="{Binding BarHeight}"
                                                   RadiusX="3" RadiusY="3"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Label}"
                                                   FontSize="9"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,3,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
