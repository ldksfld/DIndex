<UserControl x:Class="DIndex.App.Views.Pages.ImportPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="32,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{StaticResource Import.Title}" Style="{StaticResource TitleLarge}" Margin="0,0,0,24"/>

            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Імпорт CSV-файлу" Style="{StaticResource TitleSmall}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"
                                Content="{StaticResource Import.OpenCSV}"
                                Command="{Binding OpenCsvCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="{StaticResource Import.Cancel}"
                                Command="{Binding CancelCommand}"
                                Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="12"
                            Visibility="{Binding PreviewText, Converter={StaticResource NullToVis}}">
                        <TextBlock Text="{Binding PreviewText}" FontFamily="Consolas" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{StaticResource Import.Generate}" Style="{StaticResource TitleSmall}" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{StaticResource Import.Count}"
                                   VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,12,0"/>
                        <Slider Grid.Column="1" Minimum="1000" Maximum="1000000"
                                Value="{Binding GenerateCount}" TickFrequency="10000"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Margin="12,0" VerticalAlignment="Center"
                                   FontFamily="Consolas" Foreground="{StaticResource TextPrimaryBrush}">
                            <Run Text="{Binding GenerateCount, Mode=OneWay}"/>
                        </TextBlock>
                        <Button Grid.Column="3" Style="{StaticResource SuccessButton}"
                                Content="{StaticResource Import.GenerateBtn}"
                                Command="{Binding GenerateCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource BoolNegate}}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="20" Margin="0,0,0,16"
                    Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding ProgressText}" Style="{StaticResource BodyText}" Margin="0,0,0,8"/>
                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="6"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="20"
                    Visibility="{Binding ResultText, Converter={StaticResource NullToVis}}">
                <TextBlock Text="{Binding ResultText}" Foreground="{StaticResource SuccessBrush}"
                           FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold"/>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
